{
  "manifest_version": 3,
  "name": "House Vote Importer",
  "version": "0.1.0",
  "description": "Capture Airbnb and VRBO listings into House Vote.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "House Vote Importer"
  }
}
