// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Stub User model - Clerk handles user data, but we need relations
model User {
  id                 String    @id // Clerk User ID
  trips              Trip[]    @relation("OwnedTrips")
  collaboratingTrips Trip[]    @relation("TripCollaborators")
  listingsAdded      Listing[] @relation("AddedByUser")
  likes              Like[]
}

model Trip {
  id             String           @id @default(cuid())
  /// @zod.min(3, { message: "Trip name must be at least 3 characters" })
  name           String
  /// @zod.optional().nullable()
  description    String?
  /// @zod.optional().nullable()
  startDate      DateTime?
  /// @zod.optional().nullable()
  endDate        DateTime?
  /// @zod.optional().nullable()
  location       String?
  /// @zod.int().positive().optional().nullable()
  numberOfPeople Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  userId         String
  user           User             @relation("OwnedTrips", fields: [userId], references: [id], onDelete: Cascade)
  collaborators  User[]           @relation("TripCollaborators")
  listings       Listing[]
  votes          TripVote[]
  comments       ListingComment[]
  guests         TripGuest[]
  share          TripShare?
  importToken    TripImportToken?
  invitations    TripInvitation[]

  /// @zod.refine((data) => !data.startDate || !data.endDate || data.endDate >= data.startDate, { message: "End date must be after start date", path: ["endDate"] })
  @@index([userId])
}

model Listing {
  id               String              @id @default(cuid())
  /// @zod.min(1, { message: "Title cannot be empty" })
  title            String // Required
  address          String? // Optional
  url              String? // Optional
  price            Int? // Optional
  bedroomCount     Int? // Optional
  bedCount         Int? // Optional
  bathroomCount    Int? // Optional
  sourceDescription String?
  notes            String?
  imageUrl         String? // Optional
  latitude         Float?
  longitude        Float?
  source           ListingSource       @default(MANUAL)
  listingType      ListingType         @default(HOUSE)
  importMethod     ListingImportMethod @default(MANUAL)
  importStatus     ListingImportStatus @default(NOT_IMPORTED)
  sourceExternalId String?
  importedAt       DateTime?
  importError      String?
  rawImportPayload Json?
  roomBreakdown    Json?
  /// Where the stored `price` (nightly) came from. Null on legacy rows that predate this field.
  nightlyPriceSource   NightlyPriceSource?
  /// When scraping a hotel/OTA page the price is for a specific stay. These record that stay window so we can show "quoted for Mar 3-7" on cards.
  priceQuotedStartDate DateTime?
  priceQuotedEndDate   DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  addedById        String? // Optional
  addedBy          User?               @relation("AddedByUser", fields: [addedById], references: [id], onDelete: Cascade)
  addedByGuestId   String?
  addedByGuest     TripGuest?          @relation("AddedByGuest", fields: [addedByGuestId], references: [id], onDelete: SetNull)
  addedByGuestName String?
  tripId           String
  trip             Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  likes            Like[]
  votes            TripVote[]
  comments         ListingComment[]
  photos           ListingPhoto[]
  status           ListingStatus       @default(POTENTIAL)

  @@index([addedById])
  @@index([addedByGuestId])
  @@index([source, importStatus])
  @@index([sourceExternalId])
  @@index([tripId])
  @@index([listingType])
}

model ListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listingId, position])
  @@index([listingId])
}

model Like {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestDisplayName String?
  listingId        String
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([listingId])
}

enum ListingStatus {
  POTENTIAL
  REJECTED
  // Add other potential statuses later, e.g., VISITED, OFFERED
}

enum ListingSource {
  MANUAL
  AIRBNB
  VRBO
  UNKNOWN
  OTHER
}

/// Orthogonal to ListingSource. `source` says where the data came from;
/// `listingType` says what kind of lodging it is. A Marriott scrape is
/// `source=OTHER, listingType=HOTEL`; a manual Airbnb is `source=MANUAL, listingType=HOUSE`.
enum ListingType {
  HOUSE
  HOTEL
  APARTMENT
  CABIN
  RESORT
  OTHER
}

/// Describes how the `price` field (always stored as nightly) was derived.
/// SCRAPED_NIGHTLY: parsed directly as a per-night price.
/// DERIVED_FROM_TOTAL: OTA showed a total-for-stay; we divided by nights.
/// MANUAL: user typed it.
enum NightlyPriceSource {
  SCRAPED_NIGHTLY
  DERIVED_FROM_TOTAL
  MANUAL
}

enum ListingImportMethod {
  MANUAL
  URL_FETCH
  EXTENSION
}

enum ListingImportStatus {
  NOT_IMPORTED
  PARTIAL
  COMPLETE
  FAILED
}

model TripInvitation {
  id        String       @id @default(cuid())
  email     String?
  token     String       @unique
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  expiresAt DateTime
  tripId    String
  trip      Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, email])
  @@index([tripId])
  @@index([token])
  @@index([email])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// New model to track guests who joined via shareable link
model TripGuest {
  id               String           @id @default(cuid())
  tripId           String
  guestDisplayName String // Name the guest provided
  source           TripGuestSource  @default(OWNER_ADDED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  trip             Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  addedListings    Listing[]        @relation("AddedByGuest")
  votes            TripVote[]
  comments         ListingComment[]

  @@unique([tripId, guestDisplayName]) // Prevent duplicate names per trip
  @@index([tripId])
}

model TripShare {
  id                    String    @id @default(cuid())
  tripId                String    @unique
  token                 String    @unique
  isPublished           Boolean   @default(false)
  votingOpen            Boolean   @default(true)
  commentsOpen          Boolean   @default(true)
  allowGuestSuggestions Boolean   @default(true)
  publishedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  trip                  Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([token])
}

model TripVote {
  id        String    @id @default(cuid())
  tripId    String
  guestId   String
  listingId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  guest     TripGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([tripId, guestId])
  @@index([tripId])
  @@index([guestId])
  @@index([listingId])
}

model ListingComment {
  id        String    @id @default(cuid())
  tripId    String
  guestId   String
  listingId String
  kind      ListingCommentKind @default(COMMENT)
  body      String
  hiddenAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  guest     TripGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([guestId])
  @@index([listingId])
}

enum ListingCommentKind {
  COMMENT
  PRO
  CON
}

enum TripGuestSource {
  OWNER_ADDED
}

model TripImportToken {
  id         String    @id @default(cuid())
  tripId     String    @unique
  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?

  @@index([tripId])
}
