# Required for Prisma generate, build, and runtime DB access.
DATABASE_URL=

# Optional but recommended for production migrations when your runtime URL is pooled.
# Vercel's production build can use this value for `prisma migrate deploy`.
DIRECT_DATABASE_URL=

# Clerk is required for authenticated routes and owner workflows.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Chrome extension session sync. Use the House Vote web origin, for example:
# HOUSE_VOTE_EXTENSION_SYNC_HOST=http://localhost:3000
HOUSE_VOTE_EXTENSION_SYNC_HOST=
